#!/usr/bin/env bash
# qa — run all tests and quality checks.
# If invoked from a project that has its own ./qa, delegate to it.
# Otherwise run the pulse_bot checks below.
# Usage:
#   qa            — quick checks (pre-commit, ~5 sec)
#   qa --full     — quick + verify300 integration test (~25 min)

SELF="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"
LOCAL_QA="$PWD/qa"
if [ -x "$LOCAL_QA" ] && [ "$LOCAL_QA" != "$SELF" ]; then
    exec "$LOCAL_QA" "$@"
fi

cd "$(dirname "$0")"
source .venv/bin/activate

PASS=0
FAIL=0
WARN=0

run() {
    echo ""
    echo "── $1 ──"
    if eval "$2"; then
        echo "  ✓ $1"
        ((PASS++))
    else
        echo "  ✗ $1 FAILED"
        ((FAIL++))
    fi
}

warn() {
    echo ""
    echo "── $1 (advisory) ──"
    eval "$2"
    ((WARN++))
}

# Hard checks — must pass
run "Compile"         "python -m compileall -q pulse_bot/"
run "Ruff"            "ruff check pulse_bot/"
run "Black"           "black --check --quiet pulse_bot/"
run "isort"           "isort --check-only --quiet pulse_bot/"
run "Mypy"            "mypy pulse_bot/ --ignore-missing-imports --no-error-summary"
run "Bandit"          "bandit -r pulse_bot/ -q --skip B101,B608"
run "Unit Tests"      "set -a && source .env 2>/dev/null; set +a; PYTHONPATH= pytest tests/pulse_bot/ -v --noconftest --rootdir=tests/pulse_bot"

# Full mode: run verify300
if [ "$1" = "--full" ]; then
    run "Verify 300"  "./verify300"
fi

# Soft checks — advisory, don't block commit
warn "Docstrings"     "pydocstyle pulse_bot/ --count --select=D100,D101,D102,D103 2>&1 | tail -1"
warn "TODOs"          "grep -rn 'TODO\|FIXME\|HACK\|XXX' pulse_bot/ || echo '  None found'"
warn "Print stmts"    "ruff check pulse_bot/ --select=T201 --statistics 2>&1 | grep T201 || echo '  None found'"

echo ""
echo "════════════════════════════════════"
echo "  $PASS passed, $FAIL failed, $WARN advisory"
echo "════════════════════════════════════"
exit $FAIL
