#!/usr/bin/env bash
# verify300 — collect 300+ tokens live, verify backtest 100% match, verify provider data
#
# Non-destructive: uses a scratch DB (verify300_scratch.db). Never touches
# the production pulse_bot.db. Safe to run in parallel with the live bot —
# pump.fun WS supports multiple subscribers.
set -e
cd "$(dirname "$0")"
source .venv/bin/activate

SCRATCH_DB="verify300_scratch.db"
MIN_TOKENS=300
COLLECT_SECONDS=1500  # 25 minutes
KEEP_DB="${KEEP_DB:-0}"  # set KEEP_DB=1 to inspect scratch DB after run

cleanup() {
    if [ "$KEEP_DB" != "1" ]; then
        rm -f "$SCRATCH_DB" "${SCRATCH_DB}-shm" "${SCRATCH_DB}-wal"
    fi
}
trap cleanup EXIT

echo "════════════════════════════════════════════════════════════"
echo "  VERIFY 300: Live → Backtest → Provider Match Test"
echo "  Scratch DB: $SCRATCH_DB (production pulse_bot.db untouched)"
echo "════════════════════════════════════════════════════════════"

# Step 1: Fresh scratch DB (never touches pulse_bot.db)
echo ""
echo "── Step 1: Fresh scratch DB ──"
rm -f "$SCRATCH_DB" "${SCRATCH_DB}-shm" "${SCRATCH_DB}-wal"
python -c "from pulse_bot.db import Database; Database('$SCRATCH_DB').init_schema()"
echo "  ✓ Scratch DB created: $SCRATCH_DB"

# Step 2: Collect live data into scratch DB
echo ""
echo "── Step 2: Collecting live data (${COLLECT_SECONDS}s) → $SCRATCH_DB ──"
timeout $COLLECT_SECONDS python main.py monitor --db="$SCRATCH_DB" 2>&1 | tail -3 || true

LIVE_COUNT=$(python -c "
from pulse_bot.db import Database
db = Database('$SCRATCH_DB')
print(len(db.get_recent_scores(limit=99999, source='live')))
")
echo "  Live tokens scored: $LIVE_COUNT"

if [ "$LIVE_COUNT" -lt "$MIN_TOKENS" ]; then
    echo "  ⚠ Warning: $LIVE_COUNT < $MIN_TOKENS tokens (market slow). Continuing anyway."
fi

# Step 3: Verify replay (backtest = live) on scratch DB
echo ""
echo "── Step 3: Replay verify (backtest = live) ──"
python main.py verify --db="$SCRATCH_DB" 2>&1 | tee /tmp/verify300_replay.txt

REPLAY_PERFECT=$(grep -c "100%% PERFECT MATCH" /tmp/verify300_replay.txt || true)
if [ "$REPLAY_PERFECT" -eq 0 ]; then
    echo "  ✗ REPLAY FAILED — backtest does not match live"
    exit 1
fi
echo "  ✓ Replay: 100% match"

# Step 4: Provider verification — download Helius data, run Pipeline, compare with live
echo ""
echo "── Step 4: Provider verify (Helius → Pipeline → compare with live) ──"

HELIUS_KEY="${HELIUS_API_KEY:-}"
if [ -z "$HELIUS_KEY" ]; then
    if [ -f .env ]; then
        HELIUS_KEY=$(grep HELIUS_API_KEY .env | cut -d= -f2)
    fi
fi

if [ -z "$HELIUS_KEY" ]; then
    echo "  ⚠ HELIUS_API_KEY not set — skipping provider verification"
else
    python -c "
import asyncio, logging, sys, os, sqlite3
logging.basicConfig(level=logging.INFO, format='%(asctime)s %(levelname)-8s %(name)s: %(message)s', datefmt='%H:%M:%S')
log = logging.getLogger('verify300')

os.environ['HELIUS_API_KEY'] = '$HELIUS_KEY'

from pulse_bot.db import Database
from pulse_bot.collector import HeliusCollector
from pulse_bot.config import get_config
from pulse_bot.filters.fast import FastFilter
from pulse_bot.filters.scorer import Scorer
from pulse_bot.pipeline import Pipeline
from pulse_bot.sources.replay import ReplayLaunchpad

SCRATCH = '$SCRATCH_DB'

async def run():
    db = Database(SCRATCH)
    collector = HeliusCollector()

    conn = sqlite3.connect(SCRATCH)
    conn.row_factory = sqlite3.Row
    mints = [r['mint'] for r in conn.execute(
        'SELECT DISTINCT mint FROM token_scores WHERE source=\"live\" AND buy_count > 0 ORDER BY scored_at DESC LIMIT 50'
    ).fetchall()]
    conn.close()

    log.info('Downloading trades for %d mints from Helius...', len(mints))
    total = await collector.download_trades_for_mints(mints, SCRATCH)
    log.info('Downloaded %d trades from Helius', total)

    conn = sqlite3.connect(SCRATCH)
    conn.execute(\"DELETE FROM token_scores WHERE source = 'provider'\")
    conn.commit()
    conn.close()

    config = get_config()
    config.db_path = SCRATCH
    config.backtest_db_path = SCRATCH
    launchpad = ReplayLaunchpad(SCRATCH, speed=0.0)
    scorer = Scorer(config, db)
    fast_filter = FastFilter(config)
    pipeline = Pipeline(config, db, launchpad, scorer, fast_filter)
    await pipeline.run()

    conn = sqlite3.connect(SCRATCH)
    conn.row_factory = sqlite3.Row
    live_rows = {r['mint']: dict(r) for r in conn.execute('SELECT * FROM token_scores WHERE source=\"live\"').fetchall()}
    bt_rows = {r['mint']: dict(r) for r in conn.execute('SELECT * FROM token_scores WHERE source=\"backtest\"').fetchall()}

    common = set(live_rows.keys()) & set(bt_rows.keys())
    match_fast = sum(1 for m in common if (live_rows[m].get('fast_decision') or '') == (bt_rows[m].get('fast_decision') or ''))
    match_full = sum(1 for m in common if (live_rows[m].get('decision') or '') == (bt_rows[m].get('decision') or ''))
    match_score = sum(1 for m in common if live_rows[m].get('total_score', 0) == bt_rows[m].get('total_score', 0))

    total_compared = len(common)
    conn.close()

    log.info('')
    log.info('Provider comparison (Helius data → Pipeline → vs live):')
    log.info('  Compared: %d tokens', total_compared)
    log.info('  FAST decisions: %d/%d (%.1f%%)', match_fast, total_compared, match_fast / max(total_compared, 1) * 100)
    log.info('  FULL decisions: %d/%d (%.1f%%)', match_full, total_compared, match_full / max(total_compared, 1) * 100)
    log.info('  FULL scores:    %d/%d (%.1f%%)', match_score, total_compared, match_score / max(total_compared, 1) * 100)

    if match_fast == total_compared and match_full == total_compared:
        log.info('  PROVIDER: ✓ 100%% DECISIONS MATCH')
    else:
        log.info('  PROVIDER: ⚠ Some decisions differ (expected — Helius data may differ from WS)')

asyncio.run(run())
" 2>&1 | tee /tmp/verify300_provider.txt
fi

# Summary
echo ""
echo "════════════════════════════════════════════════════════════"
echo "  RESULTS:"
FAST=$(grep "FAST decisions" /tmp/verify300_replay.txt | grep -o "[0-9]*/[0-9]*" | head -1)
FULL=$(grep "FULL decisions" /tmp/verify300_replay.txt | grep -o "[0-9]*/[0-9]*" | head -1)
SCORES=$(grep "FULL scores" /tmp/verify300_replay.txt | grep -o "[0-9]*/[0-9]*" | head -1)
echo "  Replay:   FAST=$FAST  FULL=$FULL  SCORES=$SCORES"

if [ -n "$HELIUS_KEY" ] && [ -f /tmp/verify300_provider.txt ]; then
    P_FAST=$(grep "FAST decisions" /tmp/verify300_provider.txt | grep -o "[0-9]*/[0-9]*" | tail -1)
    P_FULL=$(grep "FULL decisions" /tmp/verify300_provider.txt | grep -o "[0-9]*/[0-9]*" | tail -1)
    P_SCORES=$(grep "FULL scores" /tmp/verify300_provider.txt | grep -o "[0-9]*/[0-9]*" | tail -1)
    echo "  Provider: FAST=$P_FAST  FULL=$P_FULL  SCORES=$P_SCORES"
else
    echo "  Provider: ⚠ Skipped"
fi

if [ "$REPLAY_PERFECT" -gt 0 ]; then
    echo "  OVERALL:  ✓ PASS"
    echo "════════════════════════════════════════════════════════════"
    exit 0
else
    echo "  OVERALL:  ✗ FAIL"
    echo "════════════════════════════════════════════════════════════"
    exit 1
fi
