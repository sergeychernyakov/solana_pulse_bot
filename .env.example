# .env.example — copy to .env and fill in. All PULSE_* flags are optional;
# defaults in pulse_bot/config.py kick in when unset. Marked [LIVE-only]
# values are read by the running bot at startup → restart required.

APP_ENV="development"

# ── Database (PostgreSQL) ────────────────────────────────────────
# Default ``postgresql://sergeychernyakov@localhost/pulse_bot`` if unset.
# On rich, the password is required: see /home/sergey/www/gg/.env.
PULSE_PG_DSN=postgresql://sergeychernyakov:pulsebot@localhost/pulse_bot

# ── Helius / RPC ─────────────────────────────────────────────────
# Single key (legacy) and multi-key rotation (preferred). At rest in PG
# trade collector, scoring, holder snapshot fetcher, backfill scripts.
HELIUS_API_KEY=your-key-here
HELIUS_API_KEYS=key1,key2,key3
HELIUS_RPC_URL=https://beta.helius-rpc.com/?api-key=your-key-here

# Comma-separated public RPC URLs used by ``scripts/helius_backfill_graduated.py``.
# On rich the local Solana validator at 127.0.0.1:8899 is preferred (no
# rate limit) once it's caught up; Helius URLs serve as fallback.
PUBLIC_RPC_URLS=http://127.0.0.1:8899,https://mainnet.helius-rpc.com/?api-key=key1

# ── Entry gating (live decision) ─────────────────────────────────
# Active policy: "rules" | "hybrid" (rules + ML override).
PULSE_POLICY=hybrid

# Entry mode for the rules pre-filter: "fast" | "full" | "both".
PULSE_ENTRY_MODE=full

# Force the grey-zone (RULES bucket from entry_model.meta) to SKIP rather
# than passing through to the rules engine. WR=0.57% on grey zone makes
# it the largest loss source.
PULSE_ENTRY_GREY_TO_SKIP=1

# Override the meta-tuned proba_ceiling. Useful for sweeps or if the
# operator wants stricter/looser ML override behavior than training
# selected. Live current: 0.15.
PULSE_ENTRY_PROBA_CEILING=0.15
# PULSE_ENTRY_PROBA_FLOOR=0.057

# Reg-PnL soft floor (2026-04-29). When the regression head predicts
# realized_pnl_pct < this value, refuse the ml_override BUY. Default
# -100 = disabled. Live current: -10.0 (kill bottom-decile predictions).
PULSE_ENTRY_REG_FLOOR_PCT=-10.0

# Allow loading models with status != "ok" (degenerate / narrow_proba_spread
# / auc_regression). Default 0 = refuse. Set 1 only if you know what
# you're doing — rules path is unaffected by ML status.
PULSE_ALLOW_DEGENERATE_MODEL=0

# ── T+30 early-decision model ─────────────────────────────────────
# Activate the LIVE T+30 path (BUY + SKIP override main entry).
PULSE_ENTRY_T30_ACTIVE=0

# Activate ONLY the SKIP-side of T+30 (free observation slot on
# obvious DOA tokens; main T+90 ml_override still gets to run on
# borderline tokens). Live current: 1.
PULSE_ENTRY_T30_SKIP_ACTIVE=1

# Tail proba thresholds for T+30 confidence gates. SKIP_TAIL=0.005
# means SKIP_EARLY only fires on tokens with proba<0.005 (extreme low
# tail) — leaves room for main model on borderline tokens. Default 0.005.
PULSE_T30_SKIP_TAIL=0.005
PULSE_T30_BUY_TAIL=0.85

# Shadow mode — log T+30 verdicts to t30_shadow without acting on them.
PULSE_ENTRY_T30_SHADOW=1

# ── Exit config (live ExitManager) ───────────────────────────────
# Optimizer-found values from replay sweep on 700 actually-entered
# paper_trades (2026-04-29). Best combo by total simulated PnL.
PULSE_EXIT_TAKE_PROFIT_PCT=30
PULSE_EXIT_HARD_STOP_LOSS_PCT=8
PULSE_EXIT_MAX_HOLD_SECONDS=120
PULSE_EXIT_INACTIVITY_SECONDS=60

# ── Exit ML (shadow only — not yet active) ───────────────────────
# Activate quantile heads (sl/tp/max_hold) — only after a 2-week
# paired-bootstrap shadow validation. Currently disabled.
PULSE_EXIT_REGRESSION_ACTIVE=0
PULSE_EXIT_MAX_HOLD_DYNAMIC=0
PULSE_EXIT_QUANTILE_SHADOW=1

# Activate survival head (per-tick P(survival) every 10s on each open
# paper trade). Disabled until labels improve.
PULSE_SURVIVAL_ACTIVE=0
PULSE_SURVIVAL_SHADOW=1

# Activate entry-timing checkpoints in BUY/SKIP mode (currently the
# model fires BUY_EARLY/SKIP_EARLY at confidence_floor=0.6).
PULSE_TIMING_ACTIVE=1
PULSE_TIMING_SHADOW=1

# ── Data collection ─────────────────────────────────────────────
# Continue saving trades for N seconds after a SKIP decision so ML
# label / sweep pipelines see beyond observe_seconds. 0 = disabled
# (legacy bot behavior — 99% of tokens become DOA in dataset). Live: 600.
PULSE_EXTENDED_OBSERVE_SECONDS=600

# Collector-only mode: score every token but never open paper trades.
# Used for accumulating signal data without contaminating paper_trades
# during config tuning.
PULSE_COLLECTOR_ONLY=0

# ── Observability ───────────────────────────────────────────────
# Prometheus-style /metrics endpoint port. 0 = disable.
PULSE_METRICS_PORT=9100

# ── Internal ────────────────────────────────────────────────────
# Tick interval for paper-trade survival check + price polling.
PULSE_TICK_SECONDS=5
